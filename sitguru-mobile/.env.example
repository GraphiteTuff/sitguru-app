# SitGuru mobile Supabase public client configuration.
# Use publishable key or anon public key only for client-side mobile.
# Do not put service role keys in the mobile app.
# Do not commit .env.local.
# RLS must protect production data later.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback only if needed:
EXPO_PUBLIC_SUPABASE_ANON_KEY=
